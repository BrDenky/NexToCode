---
import BaseLayout from '../layouts/BaseLayout.astro';
import LabCard from '../components/LabCard.astro';
import { getCollection } from 'astro:content';

const allLabs = await getCollection('labs');
const featuredLabs = allLabs
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())
  .slice(0, 3);
---

<BaseLayout title="Inicio" description="Blog de laboratorios de programación. C++, Python y más.">

  <!-- Hero Section -->
  <section class="relative overflow-hidden py-28 px-6">
    <!-- Decorative background blobs -->
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -left-40 w-[600px] h-[600px] rounded-full opacity-20"
        style="background: radial-gradient(circle, var(--color-accent), transparent 70%);"></div>
      <div class="absolute -bottom-40 -right-40 w-[500px] h-[500px] rounded-full opacity-15"
        style="background: radial-gradient(circle, #00adb5, transparent 70%);"></div>
    </div>

    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-block px-4 py-2 rounded-full text-sm font-mono mb-6 border"
        style="background-color: var(--color-accent-subtle); color: var(--color-accent); border-color: var(--color-accent);">
        ⚡ Aprende · Experimenta · Domina
      </div>

      <h1 class="text-5xl sm:text-6xl font-extrabold mb-6 leading-tight tracking-tight" style="color: var(--color-text-primary);">
        Bienvenido a
        <span style="
          background: linear-gradient(135deg, var(--color-accent), #00adb5);
          -webkit-background-clip: text;
          -webkit-text-fill-color: transparent;
          background-clip: text;
        "> NexToCode</span>
      </h1>

      <p class="text-xl leading-relaxed max-w-2xl mx-auto mb-10" style="color: var(--color-text-secondary);">
        Un blog de laboratorios prácticos de programación. Cada laboratorio incluye explicación teórica,
        código real y un entorno interactivo para ejecutarlo directamente en el navegador.
      </p>

      <div class="flex flex-wrap justify-center gap-4">
        <a href="/labs"
          class="px-8 py-3 rounded-xl font-semibold text-white transition-all hover:scale-105 hover:shadow-lg"
          style="background: linear-gradient(135deg, var(--color-accent), #00adb5);">
          Explorar laboratorios
        </a>
        <a href="/about"
          class="px-8 py-3 rounded-xl font-semibold border transition-all hover:scale-105"
          style="border-color: var(--color-border); color: var(--color-text-primary); background-color: var(--color-surface);">
          Sobre mí
        </a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="border-y py-8 px-6" style="border-color: var(--color-border); background-color: var(--color-surface);">
    <div class="max-w-4xl mx-auto grid grid-cols-3 gap-6 text-center">
      <div>
        <p class="text-3xl font-bold" style="color: var(--color-accent);">{allLabs.length}</p>
        <p class="text-sm" style="color: var(--color-text-secondary);">Laboratorios</p>
      </div>
      <div>
        <p class="text-3xl font-bold" style="color: var(--color-accent);">1</p>
        <p class="text-sm" style="color: var(--color-text-secondary);">Lenguajes</p>
      </div>
      <div>
        <p class="text-3xl font-bold" style="color: var(--color-accent);">∞</p>
        <p class="text-sm" style="color: var(--color-text-secondary);">Por aprender</p>
      </div>
    </div>
  </section>

  <!-- Featured Labs -->
  {featuredLabs.length > 0 && (
    <section class="max-w-6xl mx-auto px-6 py-20">
      <div class="flex items-center justify-between mb-10">
        <div>
          <h2 class="text-3xl font-bold" style="color: var(--color-text-primary);">Últimos laboratorios</h2>
          <p class="mt-1" style="color: var(--color-text-secondary);">Los más recientes del blog</p>
        </div>
        <a href="/labs" class="text-sm font-medium hover:underline" style="color: var(--color-accent);">
          Ver todos →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredLabs.map((lab) => (
          <LabCard
            titulo={lab.data.titulo}
            descripcion={lab.data.descripcion}
            lenguaje={lab.data.lenguaje}
            dificultad={lab.data.dificultad}
            etiquetas={lab.data.etiquetas}
            fecha={lab.data.fecha}
            slug={lab.id}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Languages Section -->
  <section class="px-6 py-16" style="background-color: var(--color-surface);">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-2xl font-bold mb-4" style="color: var(--color-text-primary);">Lenguajes disponibles</h2>
      <p class="mb-10" style="color: var(--color-text-secondary);">Actualmente y lo que viene...</p>
      <div class="flex flex-wrap justify-center gap-4">
        {[
          { name: 'C++', color: '#00ADB5', status: 'Disponible' },
          { name: 'Python', color: '#3572A5', status: 'Próximamente' },
          { name: 'Rust', color: '#DEA584', status: 'Próximamente' },
        ].map(({ name, color, status }) => (
          <div class="flex items-center gap-3 px-5 py-3 rounded-xl border"
            style={`border-color: ${color}44; background-color: ${color}11;`}>
            <span class="w-3 h-3 rounded-full" style={`background-color: ${color};`}></span>
            <span class="font-semibold" style={`color: ${color};`}>{name}</span>
            <span class="text-xs px-2 py-0.5 rounded-full" style={`background-color: ${color}22; color: ${color};`}>{status}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
