---
import BaseLayout from '../layouts/BaseLayout.astro';

// Single dynamic language spec for Python
const languages = [
  { 
    name: 'Python', 
    color: '#ffd200', 
    status: 'READY', 
    desc: '¡El lenguaje preferido para crear juegos y dar vida a tus robots! Aprende de forma divertida dibujando y jugando.', 
    difficulty: 'FÁCIL' 
  }
];

const modes = [
  {
    title: 'Crear Personaje',
    color: '#ff007f',
    desc: '¡Crea y entrena a tu héroe de código! Completa 10 misiones para evolucionar tu avatar, ganar accesorios retro y desbloquear superpoderes digitales.',
    specs: ['10 MISIONES', 'AVATAR EVOLUTIVO'],
    status: 'EN DESARROLLO'
  },
  {
    title: 'Alcanza la Meta',
    color: '#00f0ff',
    desc: '¡El gran viaje de la programación! Supera 50 niveles de lógica y puzzles de código en laberintos interactivos. ¡Domina las variables y llega a la meta!',
    specs: ['50 NIVELES', 'PUNTUACIÓN MÁXIMA'],
    status: 'EN DESARROLLO'
  },
  {
    title: 'Dibújalo Todo',
    color: '#39ff14',
    desc: '¡El modo creativo interactivo! Dibuja libremente en la pantalla y mira cómo tus trazos se convierten en botones y cajas de texto reales para crear tus propios videojuegos al instante.',
    specs: ['MODO CREATIVO'],
    status: 'PRÓXIMAMENTE'
  }
];
---

<BaseLayout title="Inicio" description="Plataforma interactiva de programación para niños de escuela.">

  <!-- Hero / Arcade Screen Section -->
  <section class="relative overflow-hidden border-4 border-black dark:border-border bg-surface my-8 p-8 sm:p-12 shadow-[8px_8px_0px_var(--color-shadow)]">
    <!-- Retro wireframe grid background -->
    <div class="absolute inset-0 -z-10 pointer-events-none opacity-[0.08] dark:opacity-[0.12]"
      style="background-image: linear-gradient(var(--color-border) 2px, transparent 2px), linear-gradient(90deg, var(--color-border) 2px, transparent 2px); background-size: 24px 24px;"></div>
    
    <div class="max-w-3xl">
      <!-- Animated badge -->
      <div class="inline-block px-3 py-1 text-xs font-arcade-class mb-6 border-2 border-black dark:border-border bg-surface"
        style="box-shadow: 2.5px 2.5px 0px var(--color-shadow);">
        <span class="text-accent animate-pulse font-bold">DISEÑA</span> · JUEGA · <span class="text-accent animate-pulse font-bold">APRENDE</span>
      </div>

      <h1 class="text-4xl sm:text-6xl font-retro-class leading-none mb-6 tracking-wide text-text-primary">
        BIENVENIDO A <span class="text-accent font-arcade-class text-2xl sm:text-4xl block sm:inline mt-2 sm:mt-0 tracking-tighter">NexToCode</span>
      </h1>

      <p class="text-base leading-relaxed max-w-2xl mb-8 font-mono" style="color: var(--color-text-secondary);">
        Aprende a programar de la forma más divertida. Juega misiones emocionantes, sube de nivel, 
        diseña tu avatar y crea interfaces interactivas dibujando en tiempo real.
      </p>

      <div class="flex flex-wrap gap-4">
        <a href="/labs" class="btn-retro !bg-accent !text-white hover:!bg-accent-hover hover:border-black">
          [ INICIAR PARTIDA ]
        </a>
        <a href="/about" class="btn-retro">
          [ SOBRE NOSOTROS ]
        </a>
      </div>
    </div>
  </section>

  <!-- Selector de Modo Section -->
  <section class="py-8 mb-12">
    <div class="mb-8">
      <h2 class="text-3xl sm:text-4xl font-retro-class text-text-primary font-bold">[ SELECCIONAR MODO ]</h2>
      <p class="text-xs sm:text-sm font-arcade-class mt-1 tracking-tighter" style="color: var(--color-text-secondary);">ELIGE TU MODO DE JUEGO PARA EMPEZAR</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {modes.map(({ title, color, desc, specs, status }) => (
        <div 
          class="card-retro p-6 border-4 bg-surface flex flex-col justify-between relative select-none"
          style={`border-color: var(--color-text-primary); hover:border-color: ${color};`}
        >
          <!-- Status Tag -->
          <span 
            class="absolute top-3 right-3 text-[0.55rem] font-arcade-class px-1.5 py-0.5 border-2 bg-surface"
            style={`color: ${color}; border-color: ${color}; box-shadow: 1.5px 1.5px 0px ${color};`}
          >
            {status}
          </span>

          <div class="mt-4">
            <h3 class="text-2xl font-retro-class font-bold mb-3" style={`color: ${color};`}>
              {title.toUpperCase()}
            </h3>
            
            <!-- Tech specs/features -->
            <div class="flex flex-wrap gap-2 mb-4">
              {specs.map(spec => (
                <span class="px-2 py-0.5 text-[0.6rem] font-arcade-class border border-black/40 dark:border-border/40 bg-surface/50 text-text-secondary">
                  {spec}
                </span>
              ))}
            </div>

            <p class="text-xs font-mono leading-relaxed" style="color: var(--color-text-secondary);">
              {desc}
            </p>
          </div>

          <div class="mt-8 pt-4 border-t border-dashed border-black/25 dark:border-border/25">
            <span class="text-xs font-arcade-class block text-center text-text-secondary opacity-50 select-none py-1">
              [ BLOQUEADO ]
            </span>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Lenguajes Disponibles (Character Select style) -->
  <section class="border-4 border-double border-black dark:border-border p-8 bg-surface shadow-[6px_6px_0px_var(--color-shadow)] mb-16">
    <div class="text-center mb-8">
      <h2 class="text-3xl font-retro-class font-bold text-text-primary">[ LENGUAJES DISPONIBLES ]</h2>
      <p class="text-xs font-arcade-class mt-1 tracking-tighter" style="color: var(--color-text-secondary);">ELIGE LA CLASE DE TU AVENTURERO</p>
    </div>
    
    <div class="max-w-md mx-auto">
      {languages.map(({ name, color, status, desc, difficulty }) => (
        <div 
          class="border-4 border-black dark:border-border p-5 bg-surface relative select-none flex flex-col justify-between transition-transform duration-200 hover:-translate-y-1 hover:shadow-[4px_4px_0px_var(--color-shadow)]"
          style={`border-color: ${color}; box-shadow: 4px 4px 0px ${color};`}
        >
          <!-- Status tag top right -->
          <span 
            class="absolute top-2 right-2 text-[0.55rem] font-arcade-class px-1.5 py-0.5 border"
            style={`
              background-color: ${color}22;
              color: ${color};
              border-color: ${color};
            `}
          >
            {status}
          </span>
          
          <div class="mt-4">
            <span class="text-4xl font-retro-class font-bold block" style={`color: ${color};`}>
              {name}
            </span>
            <span class="text-[0.6rem] font-arcade-class text-text-secondary block mt-1">NIVEL: {difficulty}</span>
            <p class="text-xs font-mono mt-4 leading-relaxed" style="color: var(--color-text-secondary);">
              {desc}
            </p>
          </div>
          
          <div class="mt-6 pt-4 border-t border-dashed border-black/25 dark:border-border/25">
            <a href={`/labs`} class="text-xs font-arcade-class block text-center text-accent hover:underline py-1">
              [ SELECCIONAR HÉROE > ]
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>

</BaseLayout>
