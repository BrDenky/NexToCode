---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Sobre mí" description="Conoce al creador de NexToCode.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <!-- Avatar + name Bezel Panel -->
    <div
      class="flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-14 border-4 border-black dark:border-border p-6 bg-surface shadow-[6px_6px_0px_var(--color-shadow)]"
    >
      <!-- Pixel Monitor SVG instead of 👨‍💻 emoji -->
      <div
        class="w-24 h-24 flex items-center justify-center flex-shrink-0 border-4 border-black dark:border-border bg-code-bg shadow-[2px_2px_0px_var(--color-shadow)]"
      >
        <svg
          width="48"
          height="48"
          viewBox="0 0 16 16"
          class="text-text-primary"
          fill="currentColor"
        >
          <!-- Monitor Bezel -->
          <path d="M1 1h14v10H1V1zm1 1v8h12V2H2z"></path>
          <!-- Screen contents (Simulated code lines) -->
          <rect
            x="4"
            y="4"
            width="4"
            height="1"
            class="text-accent"
            style="fill: var(--color-accent);"></rect>
          <rect
            x="4"
            y="6"
            width="6"
            height="1"
            class="text-accent"
            style="fill: var(--color-accent);"></rect>
          <rect
            x="4"
            y="8"
            width="5"
            height="1"
            class="text-accent"
            style="fill: var(--color-accent);"></rect>
          <!-- Neck -->
          <rect x="7" y="11" width="2" height="2"></rect>
          <!-- Base -->
          <rect x="4" y="13" width="8" height="2"></rect>
        </svg>
      </div>
      <div>
        <h1 class="text-4xl font-retro-class font-bold mb-2 text-text-primary">
          [ Mateo Pilaquinga ]
        </h1>
        <p
          class="text-lg font-retro-class uppercase tracking-wider"
          style="color: var(--color-accent);"
        >
          Desarrollador Web
        </p>
        <p class="text-xs font-arcade-class text-text-secondary mt-3">
          STATUS: RUNNING
        </p>
      </div>
    </div>

    <!-- Content Achievements Panels -->
    <div
      class="space-y-8"
      style="color: var(--color-text-secondary); line-height: 1.8;"
    >
      <!-- Panel 1 -->
      <div class="card-retro p-6">
        <h2 class="text-2xl font-retro-class font-bold mb-3 text-text-primary">
          &gt; ¿Qué es NexToCode?
        </h2>
        <p class="font-mono text-sm leading-relaxed">
          NexToCode nació como una bitácora técnica interactiva. El objetivo es
          documentar el aprendizaje de algoritmos y patrones de diseño a través
          de simulaciones en tiempo real. Cada laboratorio representa un desafío
          superado, empaquetado para que experimentes directamente con el código
          sin instalar dependencias locales.
        </p>
      </div>

      <!-- Panel 2 -->
      <div class="card-retro p-6">
        <h2 class="text-2xl font-retro-class font-bold mb-3 text-text-primary">
          &gt; Misiones de simulación
        </h2>
        <ul class="space-y-3 font-mono text-sm">
          {
            [
              "SYS_ACTIVE: Laboratorios interactivos en C++ Moderno (C++17/20/23)",
              "SYS_PENDING: Python para automatización y análisis de datos",
              "SYS_LOCKED: Rust para programación de sistemas de baja latencia",
              "SYS_INFO: Explicaciones teóricas modulares integradas",
            ].map((item) => {
              const isActive = item.startsWith("SYS_ACTIVE:");
              const isPending = item.startsWith("SYS_PENDING:");
              const isInfo = item.startsWith("SYS_INFO:");
              let badgeColor = "var(--color-border)";
              if (isActive) badgeColor = "var(--color-accent)";
              else if (isPending) badgeColor = "#ffd200";
              else if (isInfo) badgeColor = "#a0a6cc";

              return (
                <li class="flex items-start gap-3">
                  <span
                    class="font-arcade-class text-[0.65rem] select-none mt-1"
                    style={`color: ${badgeColor};`}
                  >
                    {isActive ? "[x]" : "[ ]"}
                  </span>
                  <span>{item.substring(item.indexOf(":") + 2)}</span>
                </li>
              );
            })
          }
        </ul>
      </div>

      <!-- Panel 3 -->
      <div class="card-retro p-6">
        <h2 class="text-2xl font-retro-class font-bold mb-3 text-text-primary">
          &gt; Stack Tecnológico
        </h2>
        <div class="flex flex-wrap gap-3 mt-4">
          {
            [
              "Astro_v6",
              "Tailwind_v4",
              "MDX",
              "Shiki",
              "Compiler_Explorer",
              "Vercel_Host",
            ].map((tech) => (
              <span
                class="px-3 py-1 font-arcade-class text-[0.6rem] border-2 border-black dark:border-border bg-surface text-text-primary"
                style="box-shadow: 2px 2px 0px var(--color-shadow);"
              >
                {tech.toUpperCase()}
              </span>
            ))
          }
        </div>
      </div>
    </div>

    <!-- CTA Start button -->
    <div class="mt-12 text-center">
      <a
        href="/labs"
        class="btn-retro !bg-accent !text-white hover:!bg-accent-hover hover:border-black"
      >
        [ ACCEDER A SIMULADOR DE MISIONES ]
      </a>
    </div>
  </div>
</BaseLayout>
