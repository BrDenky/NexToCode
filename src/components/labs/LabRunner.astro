---
/**
 * LabRunner.astro
 * Embeds a Compiler Explorer (godbolt.org) iframe so users can
 * run C++ (or other languages) directly in the browser without
 * installing any compilers locally.
 *
 * Usage:
 *   <LabRunner godboltId="someSharedId" language="cpp" />
 *   <LabRunner rawCode="int main(){...}" language="cpp" />
 */

interface Props {
  godboltId?: string;    // ID of a saved Compiler Explorer snippet
  rawCode?: string;      // Raw source code to pre-load (encoded in URL)
  language?: string;     // 'cpp' | 'python' | etc.
}

const { godboltId, rawCode, language = 'cpp' } = Astro.props;

// Compiler Explorer language identifiers
const ceLanguageMap: Record<string, string> = {
  cpp: 'c++',
  python: 'python',
  rust: 'rust',
  javascript: 'javascript',
};
const ceCompilerMap: Record<string, string> = {
  cpp: 'g142',       // GCC 14.2
  python: 'python312',
  rust: 'r1780',
  javascript: 'node2252',
};

const ceLanguage = ceLanguageMap[language] ?? 'c++';
const ceCompiler = ceCompilerMap[language] ?? 'g142';

let iframeSrc: string;

if (godboltId) {
  // Use a pre-saved permalink
  iframeSrc = `https://godbolt.org/e#${godboltId}`;
} else if (rawCode) {
  // Encode the code into a Compiler Explorer URL
  const encoded = encodeURIComponent(rawCode);
  iframeSrc = `https://godbolt.org/e#lang=${ceLanguage}&compiler=${ceCompiler}&code=${encoded}`;
} else {
  // Fallback: open a blank Compiler Explorer editor for the language
  iframeSrc = `https://godbolt.org/e#lang=${ceLanguage}&compiler=${ceCompiler}`;
}
---

<div class="border-4 border-black dark:border-border bg-surface shadow-[6px_6px_0px_var(--color-shadow)] overflow-hidden">
  <!-- Retro Terminal/Monitor header -->
  <div 
    class="flex items-center justify-between px-4 py-3 border-b-4 border-black dark:border-border select-none"
    style="background-color: var(--color-code-bg);"
  >
    <!-- Retro Arcade/Windows OS buttons -->
    <div class="flex items-center gap-1.5">
      <div class="w-5 h-5 border-2 border-black dark:border-border bg-surface flex items-center justify-center text-[10px] font-bold text-text-primary shadow-[1px_1px_0px_var(--color-shadow)]">
        _
      </div>
      <div class="w-5 h-5 border-2 border-black dark:border-border bg-surface flex items-center justify-center text-[8px] font-bold text-text-primary shadow-[1px_1px_0px_var(--color-shadow)]">
        ■
      </div>
      <div class="w-5 h-5 border-2 border-black dark:border-border bg-surface flex items-center justify-center text-[9px] font-bold text-text-primary shadow-[1px_1px_0px_var(--color-shadow)] hover:bg-accent-var hover:text-white cursor-pointer">
        X
      </div>
    </div>
    
    <!-- Monitor label -->
    <span class="text-xs font-arcade-class tracking-tighter" style="color: var(--color-accent);">
      [ CRT_COMPILER_V1.0 ]
    </span>
    
    <!-- Run Link -->
    <a
      href={iframeSrc.replace('/e#', '/#')}
      target="_blank"
      rel="noopener noreferrer"
      class="text-[0.65rem] font-arcade-class px-3 py-1.5 border-2 border-black dark:border-border bg-surface text-text-primary hover:bg-accent-subtle hover:text-accent active:translate-y-0.5 active:translate-x-0.5 transition-transform"
      style="box-shadow: 2px 2px 0px var(--color-shadow);"
    >
      FULLSCREEN >
    </a>
  </div>

  <!-- Compiler Explorer iframe -->
  <iframe
    src={iframeSrc}
    title="Compiler Explorer — Ejecutar código"
    loading="lazy"
    width="100%"
    height="500"
    class="block w-full"
    style="border: none; background-color: var(--color-code-bg);"
    allow="clipboard-write"
  />
</div>
