---
import BaseLayout from "./BaseLayout.astro";
import LabRunner from "../components/labs/LabRunner.astro";

interface Props {
  titulo: string;
  descripcion: string;
  lenguaje: string;
  dificultad: number;
  etiquetas: string[];
  fecha: Date;
  godboltId?: string;
  rawCode?: string;
}

const {
  titulo,
  descripcion,
  lenguaje,
  dificultad,
  etiquetas,
  fecha,
  godboltId,
  rawCode,
} = Astro.props;

const langColors: Record<string, string> = {
  cpp: "#00f0ff",
  python: "#ffd200",
  rust: "#ff6c00",
  javascript: "#ffe600",
};
const langLabels: Record<string, string> = {
  cpp: "C++",
  python: "Python",
  rust: "Rust",
  javascript: "JavaScript",
};

const color = langColors[lenguaje] ?? "#d90066";
const label = langLabels[lenguaje] ?? lenguaje;

const formattedDate = fecha.toLocaleDateString("es-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={titulo} description={descripcion}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 py-12">
    <!-- Breadcrumb Panel -->
    <nav class="font-retro-class text-xl mb-8 flex flex-wrap items-center gap-1 select-none" style="color: var(--color-text-secondary);">
      <a href="/" class="hover:text-accent transition-colors">[ Inicio ]</a>
      <span class="px-1 text-xs font-arcade-class opacity-50">&gt;&gt;</span>
      <a href="/labs" class="hover:text-accent transition-colors">[ Laboratorios ]</a>
      <span class="px-1 text-xs font-arcade-class opacity-50">&gt;&gt;</span>
      <a href={`/labs/${lenguaje}`} class="hover:text-accent transition-colors capitalize">[ {label} ]</a>
      <span class="px-1 text-xs font-arcade-class opacity-50">&gt;&gt;</span>
      <span class="text-accent font-bold">{titulo}</span>
    </nav>

    <!-- Lab Console Header -->
    <header class="border-4 border-black dark:border-border p-6 sm:p-8 bg-surface shadow-[6px_6px_0px_var(--color-shadow)] mb-12">
      <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
        <!-- Language cartridge label -->
        <span
          class="px-3 py-1 font-arcade-class text-xs font-bold uppercase tracking-wider bg-surface border-2"
          style={`border-color: ${color}; color: ${color}; box-shadow: 2.5px 2.5px 0px ${color};`}
        >
          {label}
        </span>
        
        <!-- Difficulty volume style meter -->
        <div class="flex items-center gap-1" title={`Dificultad: ${dificultad}/5`}>
          <span class="font-retro-class text-lg uppercase mr-2" style="color: var(--color-text-secondary);">Dificultad:</span>
          {Array.from({ length: 5 }, (_, i) => (
            <span 
              class="w-3.5 h-5 border-2 transition-colors duration-200"
              style={{
                backgroundColor: i < dificultad ? color : 'transparent',
                borderColor: i < dificultad ? color : 'var(--color-border)',
              }}
            />
          ))}
        </div>
        
        <!-- Timestamp -->
        <span class="font-retro-class text-lg px-2 border border-dashed border-black/40 dark:border-border/40" style="color: var(--color-text-secondary);">
          {formattedDate}
        </span>
      </div>

      <h1
        class="text-4xl sm:text-5xl font-retro-class font-bold mb-4 leading-none tracking-wide text-text-primary"
      >
        {titulo}
      </h1>
      
      <p
        class="text-base leading-relaxed font-mono mt-4"
        style="color: var(--color-text-secondary);"
      >
        {descripcion}
      </p>

      <!-- Tags list -->
      <div class="flex flex-wrap gap-2 mt-6">
        {
          etiquetas.map((tag) => (
            <span
              class="px-2.5 py-0.5 text-xs font-mono border border-black dark:border-border bg-surface"
              style="box-shadow: 2px 2px 0px var(--color-shadow);"
            >
              #{tag}
            </span>
          ))
        }
      </div>
    </header>

    <!-- Lab content container -->
    <div
      class="prose prose-invert max-w-none text-text-primary mb-16"
      style="--tw-prose-body: var(--color-text-primary); --tw-prose-headings: var(--color-text-primary); --tw-prose-links: var(--color-accent);"
    >
      <slot />
    </div>

    <!-- Runner: Compiler Explorer iframe -->
    {
      (godboltId || rawCode) && (
        <div class="mt-16">
          <div class="font-arcade-class text-xs text-accent mb-4 animate-pulse">
            [ SYSTEM: INTERACTIVE_RUNNER_LOADED ]
          </div>
          <LabRunner
            godboltId={godboltId}
            rawCode={rawCode}
            language={lenguaje}
          />
        </div>
      )
    }

    <!-- Navigation footer button -->
    <div class="mt-20 pt-8 border-t-4 border-dashed border-black/30 dark:border-border/30 flex justify-start">
      <a
        href="/labs"
        class="btn-retro"
      >
        &lt;&lt; VOLVER A LOS LABORATORIOS
      </a>
    </div>
  </article>
</BaseLayout>
