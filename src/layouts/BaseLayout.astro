---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Blog de laboratorios y aprendizaje de programación.' } = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | NexToCode</title>
  </head>
  <body class="min-h-screen flex flex-col font-sans antialiased">

    <!-- Header -->
    <header class="sticky top-0 z-50 backdrop-blur-md border-b" style="background-color: color-mix(in srgb, var(--color-surface) 85%, transparent); border-color: var(--color-border);">
      <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold text-xl" style="color: var(--color-text-primary);">
          <span class="text-2xl">⚡</span>
          <span>NexTo<span style="color: var(--color-accent);">Code</span></span>
        </a>
        <div class="flex items-center gap-6">
          <a href="/labs" class="text-sm font-medium transition-colors hover:underline" style="color: var(--color-text-secondary);">
            Laboratorios
          </a>
          <a href="/about" class="text-sm font-medium transition-colors hover:underline" style="color: var(--color-text-secondary);">
            Sobre mí
          </a>
          <button
            id="theme-toggle"
            aria-label="Cambiar tema"
            class="p-2 rounded-lg border text-sm transition-colors cursor-pointer"
            style="background-color: var(--color-surface); border-color: var(--color-border); color: var(--color-text-secondary);"
          >
            <span id="theme-icon">☀️</span>
          </button>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t py-10 mt-20" style="border-color: var(--color-border);">
      <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-sm" style="color: var(--color-text-secondary);">
          © {new Date().getFullYear()} NexToCode — Hecho con ❤️ y mucho C++.
        </p>
        <p class="text-sm" style="color: var(--color-text-secondary);">
          Construido con <a href="https://astro.build" target="_blank" class="underline hover:opacity-80">Astro</a>
        </p>
      </div>
    </footer>

    <!-- Dark mode toggle script -->
    <script>
      const toggle = document.getElementById('theme-toggle');
      const icon = document.getElementById('theme-icon');
      const html = document.documentElement;

      // Restore preference
      const saved = localStorage.getItem('theme');
      if (saved === 'light') {
        html.classList.remove('dark');
        if (icon) icon.textContent = '🌙';
      }

      toggle?.addEventListener('click', () => {
        const isDark = html.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        if (icon) icon.textContent = isDark ? '☀️' : '🌙';
      });
    </script>
  </body>
</html>
